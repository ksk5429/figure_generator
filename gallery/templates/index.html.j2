<!doctype html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>figure_generator — gallery</title>
<style>
  :root {
    --bg: #fafafa;
    --fg: #1a1a1a;
    --card: #ffffff;
    --muted: #666;
    --accent: #0b6ea0;
    --border: #e5e5e5;
  }
  html[data-theme="dark"] {
    --bg: #111416;
    --fg: #eaeaea;
    --card: #1b1f22;
    --muted: #9aa3ab;
    --accent: #5ab4d8;
    --border: #2a2f33;
  }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--bg);
    color: var(--fg);
  }
  header {
    padding: 1.4rem 2rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  h1 { margin: 0; font-size: 1.15rem; font-weight: 600; }
  .meta { color: var(--muted); font-size: 0.85rem; }
  main { padding: 1.5rem 2rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .card img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    background: #fff;
  }
  .id { font-weight: 600; font-size: 0.95rem; }
  .journal { display: inline-block; padding: 1px 6px; font-size: 0.7rem;
    background: var(--accent); color: white; border-radius: 3px; }
  .stale { background: #c23b22; }
  .fresh { background: #2a8a3f; }
  .caption { color: var(--muted); font-size: 0.8rem; }
  .meta-row { font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
    font-size: 0.7rem; color: var(--muted); overflow-x: auto; }
  button.toggle {
    background: none; border: 1px solid var(--border); color: var(--fg);
    padding: 0.3rem 0.6rem; border-radius: 4px; cursor: pointer;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
</style>
</head>
<body>
<header>
  <div>
    <h1>figure_generator — gallery</h1>
    <div class="meta">Generated {{ generated_at }} · {{ figures|length }} figures</div>
  </div>
  <button class="toggle" onclick="toggleTheme()">Toggle theme</button>
</header>
<main>
<div class="grid">
{% for fig in figures %}
  <div class="card">
    <div><span class="id">{{ fig.figure_id }}</span>
      <span class="journal">{{ fig.journal }}</span>
      <span class="journal {{ 'fresh' if fig.fresh else 'stale' }}">{{ 'fresh' if fig.fresh else 'stale' }}</span>
    </div>
    {% if fig.png %}
      <a href="{{ fig.svg or fig.png }}"><img src="{{ fig.png }}" alt="{{ fig.figure_id }}" /></a>
    {% else %}
      <div class="caption">(no output — run `make figure FIG={{ fig.figure_id }}`)</div>
    {% endif %}
    {% if fig.caption %}<div class="caption">{{ fig.caption }}</div>{% endif %}
    <div class="meta-row">git: {{ fig.git_hash or 'n/a' }} · data: {{ fig.data_sources or 'n/a' }}</div>
    <div class="meta-row">generated: {{ fig.generated_utc or 'n/a' }}</div>
  </div>
{% endfor %}
</div>
</main>
<script>
  function toggleTheme() {
    const html = document.documentElement;
    html.dataset.theme = html.dataset.theme === 'dark' ? 'light' : 'dark';
    localStorage.setItem('figgen-theme', html.dataset.theme);
  }
  (function () {
    const saved = localStorage.getItem('figgen-theme');
    if (saved) document.documentElement.dataset.theme = saved;
    else if (matchMedia('(prefers-color-scheme: dark)').matches)
      document.documentElement.dataset.theme = 'dark';
  })();
</script>
</body>
</html>
