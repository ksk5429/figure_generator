# ISFOG proceedings style. Inherits base.mplstyle via figgen.utils.load_style.
# Source: ISFOG 2025 author guidelines — single column 90 mm, double 185 mm.

figure.figsize: 3.54, 2.66
font.size: 8
axes.titlesize: 9
axes.labelsize: 8
xtick.labelsize: 7
ytick.labelsize: 7
legend.fontsize: 7
lines.linewidth: 0.8
